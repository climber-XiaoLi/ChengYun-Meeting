####### Build rules

first: all
all: Makefile.Release  release/WeChat.exe

release/WeChat.exe: D:/QT/6.8.3/mingw_64/lib/libQt6Widgets.a D:/QT/6.8.3/mingw_64/lib/libQt6Multimedia.a D:/QT/6.8.3/mingw_64/lib/libQt6Gui.a D:/QT/6.8.3/mingw_64/lib/libQt6Network.a D:/QT/6.8.3/mingw_64/lib/libQt6Core.a D:/QT/6.8.3/mingw_64/lib/libQt6EntryPoint.a ui_logindialog.h ui_roomdialog.h ui_usershowwidget.h ui_wechatdialog.h $(OBJECTS) release/WeChat_resource_res.o
	$(LINKER) $(LFLAGS) -o $(DESTDIR_TARGET) @release\object_script.WeChat.Release $(LIBS)

release/WeChat_resource_res.o: WeChat_resource.rc
	windres -i WeChat_resource.rc -o release\WeChat_resource_res.o --include-dir=. $(DEFINES)

qmake: FORCE
	@$(QMAKE) -o Makefile.Release ..\..\WeChat.pro -spec win32-g++ "CONFIG+=qtquickcompiler"

qmake_all: FORCE

